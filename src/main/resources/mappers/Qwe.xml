<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.QweDao">

    <insert id="inserta" parameterType="com.example.pojo.Qwe">
        insert into qwe(name,age) values (#{name},#{age})
    </insert>
    <select id="selectAll" resultType="com.example.pojo.Qwe">
        select * from qwe
    </select>

</mapper>
